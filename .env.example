# Copie este arquivo para .env e preencha com os dados do seu projeto Supabase
# (Project Settings -> API)
# Project URL (sem /rest/v1 no final — o SDK adiciona isso sozinho)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# URL pública do app (usada nos QR codes dos eventos)
# Local: http://localhost:5173
# Produção: https://seu-app.vercel.app
VITE_APP_URL=http://localhost:5173
